# Lovable Cloud / Supabase (publishable / anon — aman dipublikasikan)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Mirror untuk server-side (TanStack Start server functions)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
SUPABASE_PROJECT_ID="your-project-ref"

# RAHASIA — JANGAN commit. Hanya untuk server (admin operations).
SUPABASE_SERVICE_ROLE_KEY="set-via-hosting-provider-secret-store"

# Domain canonical untuk meta/SEO/sitemap. Kosongkan untuk pakai default lovable.app.
# Contoh: https://perpustakaansemestalam.vercel.app
VITE_SITE_URL=""
